<h1>Profile</h1>

<% if @user.errors.any? %>
  <div class="alert">
    <ul style="margin: 0; padding-left: 1.2rem;">
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="card" style="max-width: 520px;">
  <% avg = @user.average_rating %>
  <% if avg %>
    <p style="margin-bottom: 1rem;">
      <span class="star-rating" style="font-size: 1.1rem;">★ <%= avg %></span>
      <span class="rating-count">(<%= @user.ratings_received.count %> <%= @user.ratings_received.count == 1 ? "rating" : "ratings" %>)</span>
    </p>
  <% end %>

  <%= form_with model: @user, url: profile_path, method: :patch, local: true do |form| %>
    <div class="form-group">
      <%= form.label :first_name, "First Name", class: "form-label" %>
      <%= form.text_field :first_name, placeholder: "First name" %>
    </div>
    <div class="form-group">
      <%= form.label :last_name, "Last Name", class: "form-label" %>
      <%= form.text_field :last_name, placeholder: "Last name" %>
    </div>
    <div class="form-group">
      <%= form.label :phone_number, "Phone Number", class: "form-label" %>
      <%= form.text_field :phone_number, placeholder: "Phone number (optional)" %>
    </div>

    <div style="border-top: 1px solid var(--border); padding-top: 0.75rem; margin-top: 0.25rem; color: var(--secondary-text); font-size: 0.9rem;">
      <p><strong style="color: var(--primary-text);">Email:</strong> <%= @user.email_address %></p>
      <p style="margin-top: 0.4rem;"><strong style="color: var(--primary-text);">Last Login:</strong> <%= @user.last_login ? @user.last_login.strftime("%b %d, %Y %I:%M %p") : "—" %></p>
      <p style="margin-top: 0.4rem;"><strong style="color: var(--primary-text);">Books Added:</strong> <%= @user.total_books || 0 %></p>
    </div>

    <div style="margin-top: 1rem;">
      <%= form.submit "Save Changes", class: "button button-primary" %>
    </div>
  <% end %>
</div>
