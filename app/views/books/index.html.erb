<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
  <h1 style="margin-bottom: 0;">My Books</h1>
  <%= link_to "+ Add Book", new_book_path, class: "button button-primary" %>
</div>

<% if @books.any? %>
  <div class="books-grid">
    <% @books.each do |book| %>
      <div class="book-card">
        <h2 class="book-title"><%= book.title %></h2>
        <% if book.author.present? %>
          <p style="color: var(--secondary-text); font-size: 0.9rem; margin-bottom: 0.5rem;">by <%= book.author %></p>
        <% end %>
        <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
          <% if book.genre.present? %>
            <span class="genre-badge"><%= book.genre %></span>
          <% end %>
          <% if book.condition.present? %>
            <span class="condition-badge"><%= book.condition %></span>
          <% end %>
        </div>
        <p><strong>Status:</strong> <%= book.borrowable? ? "Borrowable" : "Not Borrowable" %></p>
        <div class="book-actions">
          <%= link_to "View", book, class: "button button-secondary" %>
          <%= link_to "Edit", edit_book_path(book), class: "button button-secondary" %>
          <%= button_to "Delete", book, method: :delete, class: "button button-secondary", form: { class: "inline-button" }, data: { turbo_confirm: "Are you sure?" } %>
        </div>
      </div>
    <% end %>
  </div>
  <%= paginate @books %>
<% else %>
  <p>You have no books yet.</p>
  <%= link_to "Add your first book", new_book_path, class: "button button-primary" %>
<% end %>
