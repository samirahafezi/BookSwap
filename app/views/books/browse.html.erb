<h1>Browse Books</h1>

<div class="search-filter-bar">
  <%= form_with url: browse_books_path, method: :get, local: true do |form| %>
    <%= form.text_field :q, value: params[:q], placeholder: "Search by title or author…" %>
    <%= form.select :genre, [["All genres", nil]] + @genres, { selected: params[:genre] }, {} %>
    <%= form.submit "Search", class: "button button-primary" %>
    <% if params[:q].present? || params[:genre].present? %>
      <%= link_to "Clear", browse_books_path, class: "button button-secondary" %>
    <% end %>
  <% end %>
</div>

<% if @books.any? %>
  <table class="books-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Genre</th>
        <th>Condition</th>
        <th>Owner</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td><strong><%= book.title %></strong></td>
          <td><%= book.author.presence || "—" %></td>
          <td><%= book.genre.present? ? content_tag(:span, book.genre, class: "genre-badge") : "—" %></td>
          <td><%= book.condition.present? ? content_tag(:span, book.condition, class: "condition-badge") : "—" %></td>
          <td>
            <%= book.user.first_name.present? ? "#{book.user.first_name} #{book.user.last_name}" : book.user.email_address %>
            <% avg = book.user.average_rating %>
            <% if avg %>
              <span class="star-rating">★ <%= avg %></span>
              <span class="rating-count">(<%= book.user.ratings_received.count %>)</span>
            <% end %>
          </td>
          <td class="table-actions">
            <%= link_to "View", book, class: "button button-secondary" %>
            <%= mail_to book.user.email_address, "Email Owner", class: "button button-secondary" %>
            <% if book.available_for_borrowing? %>
              <%= button_to "Borrow", borrow_book_path(book), method: :post, class: "button button-primary" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= paginate @books %>
<% else %>
  <p>No books found<%= " matching your search" if params[:q].present? || params[:genre].present? %>.</p>
  <% if params[:q].present? || params[:genre].present? %>
    <%= link_to "Clear filters", browse_books_path, class: "button button-secondary" %>
  <% else %>
    <p>Try again later, or add more of your own books so others can borrow from you.</p>
  <% end %>
<% end %>
