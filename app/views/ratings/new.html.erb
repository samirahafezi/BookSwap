<h1>Rate Your Experience</h1>

<div class="card" style="max-width: 480px;">
  <p style="margin-bottom: 1rem; color: var(--secondary-text);">
    You borrowed <strong style="color: var(--primary-text);"><%= @borrow.book.title %></strong>
    from <strong style="color: var(--primary-text);"><%= @borrow.book.user.first_name.present? ? "#{@borrow.book.user.first_name} #{@borrow.book.user.last_name}" : @borrow.book.user.email_address %></strong>.
  </p>

  <% if @rating.errors.any? %>
    <div class="alert">
      <ul style="margin: 0; padding-left: 1.2rem;">
        <% @rating.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [@borrow, @rating], url: borrow_rating_path(@borrow) do |form| %>
    <div class="form-group">
      <label class="form-label">Rating</label>
      <div style="display: flex; gap: 0.5rem; align-items: center; flex-direction: row;">
        <% (1..5).each do |n| %>
          <label style="display: flex; align-items: center; gap: 0.25rem; cursor: pointer;">
            <%= form.radio_button :stars, n, required: true %>
            <span class="star-rating" style="font-size: 1.2rem;">★ <%= n %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="form-group">
      <%= form.label :comment, "Comment (optional)", class: "form-label" %>
      <%= form.text_area :comment, rows: 3, placeholder: "How was the swap? Any notes about the book's condition?" %>
    </div>

    <div class="form-actions">
      <%= form.submit "Submit Rating", class: "button button-primary" %>
      <%= link_to "Skip", my_borrowed_books_path, class: "button button-secondary" %>
    </div>
  <% end %>
</div>
